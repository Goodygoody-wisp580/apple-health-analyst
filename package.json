{
  "name": "apple-health-analyst",
  "version": "1.0.0",
  "description": "在本地分析 Apple Health 导出 ZIP，并生成机器可读与人工可读报告。",
  "type": "module",
  "bin": {
    "apple-health-analyst": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "check": "npm run build && npm test"
  },
  "keywords": [
    "apple-health",
    "healthkit",
    "cli",
    "codex-skill"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "SKILL.md",
    "agents/openai.yaml",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "saxes": "^6.0.0",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/unzipper": "^0.10.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
